<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Dashboard - Multi-Campaign</title>
    <%- include('partials/header_assets') %>
    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        .sidebar { transition: transform 0.3s ease-in-out; }
        .modal { transition: opacity 0.3s ease-in-out, visibility 0.3s ease-in-out; }
        .modal-content { transition: transform 0.3s ease-in-out; }
    </style>
</head>

<body class="bg-gray-50 dark:bg-gray-900 text-gray-900 dark:text-gray-100 min-h-screen flex flex-col transition-colors duration-300">

    <%- include('partials/navbar') %>

    <div class="flex flex-1 overflow-hidden relative">

        <!-- Mobile Sidebar Overlay -->
        <div id="sidebarOverlay" class="fixed inset-0 bg-gray-900/50 backdrop-blur-sm z-40 hidden lg:hidden" onclick="toggleSidebar()"></div>

        <!-- Sidebar -->
        <aside id="sidebar" class="sidebar fixed inset-y-0 left-0 w-72 bg-white dark:bg-gray-800 border-r border-gray-200 dark:border-gray-700 z-50 transform -translate-x-full lg:translate-x-0 lg:static lg:block drop-shadow-xl lg:drop-shadow-none flex flex-col">
            
            <div class="p-6 flex-1">
                <div class="flex justify-between items-center mb-10 lg:hidden">
                    <h2 class="text-xl font-bold dark:text-white">Menu</h2>
                    <button onclick="toggleSidebar()" class="p-2 text-gray-500 hover:text-gray-900 dark:hover:text-white bg-gray-100 dark:bg-gray-700 rounded-lg">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                    </button>
                </div>

                <div class="text-xs uppercase font-semibold text-gray-500 tracking-wider mb-4 hidden lg:block">Navigation</div>
                <ul class="space-y-2">
                    <li>
                        <a href="/dashboard" class="flex items-center gap-3 px-4 py-3 bg-brand-50 text-brand-600 dark:bg-brand-900/30 dark:text-brand-400 rounded-xl font-medium transition-colors">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"></path></svg>
                            Dashboard
                        </a>
                    </li>
                    <li>
                        <a href="/transactions" class="flex items-center gap-3 px-4 py-3 text-gray-600 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-700/50 rounded-xl font-medium transition-colors">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                            Transactions
                        </a>
                    </li>
                </ul>

                <div class="mt-8">
                    <a href="/logout" class="flex items-center gap-3 px-4 py-3 text-red-600 hover:bg-red-50 dark:hover:bg-red-900/20 rounded-xl font-medium transition-colors">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path></svg>
                        Logout
                    </a>
                </div>
            </div>
            
            <div class="w-full p-6 border-t border-gray-100 dark:border-gray-700 mt-auto">
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-full bg-gradient-to-r from-brand-400 to-blue-500 text-white flex items-center justify-center font-bold text-lg shadow-sm">
                        <%= user.name.charAt(0).toUpperCase() %>
                    </div>
                    <div class="overflow-hidden">
                        <p class="font-bold text-sm truncate dark:text-white"><%= user.name %></p>
                        <p class="text-xs text-gray-500 dark:text-gray-400 truncate"><%= typeof user.email !== "undefined" ? user.email : "Member" %></p>
                    </div>
                </div>
            </div>
        </aside>

        <!-- Main Content -->
        <main class="flex-1 p-6 lg:p-10 overflow-y-auto animate-fade-in relative w-full">

            <button onclick="toggleSidebar()" class="lg:hidden flex items-center gap-2 text-gray-600 dark:text-gray-300 font-medium mb-6 hover:bg-gray-200 dark:hover:bg-gray-800 p-2 rounded-lg transition-colors">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg>
                <span>Menu</span>
            </button>

            <header class="mb-10 flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
                <div>
                    <h1 class="text-3xl font-bold dark:text-white mb-2">Overview</h1>
                    <p class="text-gray-500 dark:text-gray-400">Welcome back, <%= user.name %>!</p>
                </div>
                <button onclick="openCreateModal()" class="bg-brand-600 text-white px-5 py-2.5 rounded-xl hover:bg-brand-700 font-semibold shadow-md shadow-brand-500/30 transition-all flex items-center gap-2">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
                    New Campaign
                </button>
            </header>

            <!-- Cards Grid -->
            <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6 mb-10">
                <div class="bg-white dark:bg-gray-800 p-6 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-700 relative overflow-hidden group">
                    <div class="absolute top-0 right-0 p-6 opacity-10"><svg class="w-16 h-16 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg></div>
                    <h3 class="text-gray-500 dark:text-gray-400 font-medium mb-2 relative z-10">Total Global Donations</h3>
                    <div class="text-3xl font-extrabold text-gray-900 dark:text-white relative z-10">₹<%= totalDonations %></div>
                </div>
                <div class="bg-white dark:bg-gray-800 p-6 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-700 relative overflow-hidden group">
                    <div class="absolute top-0 right-0 p-6 opacity-10"><svg class="w-16 h-16 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path></svg></div>
                    <h3 class="text-gray-500 dark:text-gray-400 font-medium mb-2 relative z-10">Total Global Donors</h3>
                    <div class="text-3xl font-extrabold text-gray-900 dark:text-white relative z-10"><%= totalDonors %></div>
                </div>
            </div>

            <h2 class="text-2xl font-bold dark:text-white mb-6">Your Campaigns</h2>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 pb-10">
                <% if (!campaigns || campaigns.length === 0) { %>
                    <div class="col-span-full text-center py-12 bg-white dark:bg-gray-800 rounded-2xl border border-gray-100 dark:border-gray-700 border-dashed">
                        <p class="text-gray-500 dark:text-gray-400 mb-4">You don't have any active campaigns.</p>
                        <button onclick="openCreateModal()" class="text-brand-600 font-bold hover:underline">Create your first campaign &rarr;</button>
                    </div>
                <% } else { %>
                    <% campaigns.forEach(c => { %>
                        <div class="bg-white dark:bg-gray-800 p-6 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-700 flex flex-col transition hover:shadow-md">
                            <div class="flex justify-between items-start mb-4">
                                <div>
                                    <h3 class="text-xl font-bold dark:text-white truncate" title="<%= c.title %>"><%= c.title %></h3>
                                    <p class="text-sm text-gray-500 dark:text-gray-400">Target: ₹<%= c.goalAmount %> &bull; <%= c.totalDonors %> Donors</p>
                                </div>
                                <span class="px-2.5 py-1 rounded-full text-xs font-semibold <%= c.isActive ? 'bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-400' : 'bg-gray-100 text-gray-800' %>">
                                    <%= c.isActive ? 'Active' : 'Closed' %>
                                </span>
                            </div>
                            
                            <!-- Progress Bar -->
                            <% const percent = Math.min(100, Math.round((c.totalRaised / c.goalAmount) * 100)) || 0; %>
                            <div class="mb-6">
                                <div class="flex justify-between text-xs font-semibold mb-1 dark:text-gray-300">
                                    <span>₹<%= c.totalRaised %> raised</span>
                                    <span><%= percent %>%</span>
                                </div>
                                <div class="h-2 w-full bg-gray-100 dark:bg-gray-700 rounded-full overflow-hidden">
                                    <div class="h-full bg-brand-500 rounded-full" style="width: <%= percent %>%"></div>
                                </div>
                            </div>
                            
                            <div class="mt-auto grid grid-cols-2 gap-3">
                                <button onclick="copyToClipboard('<%= baseUrl %>/c/<%= c.slug %>')" class="flex items-center justify-center gap-2 py-2.5 px-4 rounded-xl border border-gray-200 dark:border-gray-700 text-sm font-semibold hover:bg-gray-50 dark:hover:bg-gray-700 transition dark:text-white">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"></path></svg>
                                    Copy Link
                                </button>
                                <button onclick="openAnalytics('<%= c._id %>')" class="flex items-center justify-center gap-2 py-2.5 px-4 rounded-xl bg-gray-900 dark:bg-brand-500 text-white text-sm font-semibold hover:opacity-90 transition">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 12l3-3 3 3 4-4M8 21l4-4 4 4M3 4h18M4 4h16v12a1 1 0 01-1 1H5a1 1 0 01-1-1V4z"></path></svg>
                                    Analytics
                                </button>
                            </div>
                        </div>
                    <% }) %>
                <% } %>
            </div>

            <!-- Global Toast -->
            <div id="toast" class="fixed bottom-10 right-10 bg-gray-900 text-white px-4 py-2 rounded-lg opacity-0 pointer-events-none transition-opacity z-50 shadow-xl">
                Copied to clipboard!
            </div>

        </main>
    </div>

    <!-- Create Campaign Modal -->
    <div id="createModal" class="modal fixed inset-0 z-50 hidden opacity-0 invisible flex items-center justify-center">
        <div class="absolute inset-0 bg-gray-900/60 backdrop-blur-sm" onclick="closeCreateModal()"></div>
        <div class="modal-content relative bg-white dark:bg-gray-800 w-full max-w-md p-8 rounded-2xl shadow-2xl transform scale-95 border border-gray-100 dark:border-gray-700">
            <h2 class="text-2xl font-bold dark:text-white mb-6">New Campaign</h2>
            <form id="createForm" class="space-y-4">
                <div>
                    <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2">Campaign Title</label>
                    <input type="text" id="c_title" required class="w-full bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-xl px-4 py-3 focus:ring-2 focus:ring-brand-500 text-gray-900 dark:text-white focus:outline-none">
                </div>
                <div>
                    <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2">Description</label>
                    <textarea id="c_desc" required rows="3" class="w-full bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-xl px-4 py-3 focus:ring-2 focus:ring-brand-500 text-gray-900 dark:text-white focus:outline-none resize-none"></textarea>
                </div>
                <div>
                    <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2">Goal Amount (₹)</label>
                    <input type="number" id="c_goal" required min="100" class="w-full bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-xl px-4 py-3 focus:ring-2 focus:ring-brand-500 text-gray-900 dark:text-white focus:outline-none">
                </div>
                <div class="pt-4 flex gap-3">
                    <button type="button" onclick="closeCreateModal()" class="flex-1 py-3 bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-300 rounded-xl font-bold hover:bg-gray-200 dark:hover:bg-gray-600">Cancel</button>
                    <button type="submit" class="flex-1 py-3 bg-brand-600 text-white rounded-xl font-bold hover:bg-brand-700 shadow-md">Create</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Analytics Modal -->
    <div id="analyticsModal" class="modal fixed inset-0 z-50 hidden opacity-0 invisible flex items-center justify-center p-4">
        <div class="absolute inset-0 bg-gray-900/60 backdrop-blur-sm" onclick="closeAnalytics()"></div>
        <div class="modal-content relative bg-white dark:bg-gray-800 w-full max-w-3xl p-6 md:p-8 rounded-2xl shadow-2xl transform scale-95 border border-gray-100 dark:border-gray-700">
            <div class="flex justify-between items-center mb-6">
                <h2 class="text-2xl font-bold dark:text-white">Donations Over Time</h2>
                <button onclick="closeAnalytics()" class="p-2 text-gray-500 hover:text-gray-900 dark:hover:text-white">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                </button>
            </div>
            <div class="w-full h-80 relative">
                <canvas id="analyticsChart"></canvas>
            </div>
            <div id="emptyAnalytics" class="hidden absolute inset-0 flex items-center justify-center bg-white/80 dark:bg-gray-800/80">
                <p class="text-gray-500 dark:text-gray-400 font-semibold">No donation data available yet.</p>
            </div>
        </div>
    </div>

<script>
function toggleSidebar() {
    document.getElementById('sidebar').classList.toggle('-translate-x-full');
    document.getElementById('sidebarOverlay').classList.toggle('hidden');
}

function copyToClipboard(text) {
    navigator.clipboard.writeText(text);
    const toast = document.getElementById('toast');
    toast.style.opacity = '1';
    toast.style.visibility = 'visible';
    setTimeout(() => { toast.style.opacity = '0'; }, 3000);
}

// Global chart instance
let myChart = null;

// Modal Toggles
const createModal = document.getElementById('createModal');
const cContent = createModal.querySelector('.modal-content');

function openCreateModal() {
    createModal.classList.remove('hidden');
    setTimeout(() => {
        createModal.classList.remove('opacity-0', 'invisible');
        cContent.classList.remove('scale-95');
    }, 10);
}

function closeCreateModal() {
    createModal.classList.add('opacity-0', 'invisible');
    cContent.classList.add('scale-95');
    setTimeout(() => createModal.classList.add('hidden'), 300);
}

// Form Submit
document.getElementById('createForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    const title = document.getElementById('c_title').value;
    const description = document.getElementById('c_desc').value;
    const goalAmount = document.getElementById('c_goal').value;

    const res = await fetch('/campaigns/create', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ title, description, goalAmount })
    });
    
    if (res.ok) {
        window.location.reload();
    } else {
        alert("Failed to create campaign");
    }
});

// Analytics Implementation
const analyticsModal = document.getElementById('analyticsModal');
const aContent = analyticsModal.querySelector('.modal-content');

async function openAnalytics(campaignId) {
    // Reveal Modal
    analyticsModal.classList.remove('hidden');
    setTimeout(() => {
        analyticsModal.classList.remove('opacity-0', 'invisible');
        aContent.classList.remove('scale-95');
    }, 10);

    // Fetch Data
    document.getElementById('emptyAnalytics').classList.add('hidden');
    const res = await fetch(`/campaigns/analytics/${campaignId}`);
    const data = await res.json();

    if (!data || data.length === 0) {
        document.getElementById('emptyAnalytics').classList.remove('hidden');
    }

    renderChart(data);
}

function closeAnalytics() {
    analyticsModal.classList.add('opacity-0', 'invisible');
    aContent.classList.add('scale-95');
    setTimeout(() => {
        analyticsModal.classList.add('hidden');
        if (myChart) myChart.destroy();
    }, 300);
}

function renderChart(data) {
    const ctx = document.getElementById('analyticsChart').getContext('2d');
    
    if (myChart) myChart.destroy();

    const labels = data.map(d => d._id);
    const amounts = data.map(d => d.totalAmount);
    
    const isDark = document.documentElement.classList.contains('dark');

    myChart = new Chart(ctx, {
        type: 'line',
        data: {
            labels: labels,
            datasets: [{
                label: 'Donations Raised (₹)',
                data: amounts,
                borderColor: '#0d9488', // teal/brand
                backgroundColor: 'rgba(13, 148, 136, 0.1)',
                borderWidth: 3,
                fill: true,
                tension: 0.4,
                pointBackgroundColor: '#fff',
                pointBorderColor: '#0d9488',
                pointBorderWidth: 2,
                pointRadius: 4
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: { display: false }
            },
            scales: {
                x: {
                    grid: { color: isDark ? 'rgba(255,255,255,0.05)' : 'rgba(0,0,0,0.05)' },
                    ticks: { color: isDark ? '#9ca3af' : '#6b7280' }
                },
                y: {
                    beginAtZero: true,
                    grid: { color: isDark ? 'rgba(255,255,255,0.05)' : 'rgba(0,0,0,0.05)' },
                    ticks: { color: isDark ? '#9ca3af' : '#6b7280' }
                }
            }
        }
    });
}
</script>

</body>
</html>