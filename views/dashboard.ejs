<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Dashboard</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100">

<div class="flex min-h-screen">

    <!-- Sidebar -->
    <div class="w-64 bg-white shadow-md p-5">
        <h2 class="text-xl font-bold mb-6">Fundraiser</h2>

        <ul class="space-y-4">
            <li><a href="/dashboard" class="text-blue-600 font-semibold">Dashboard</a></li>

            <% if (user.referralCode) { %>
                <li><a href="/transactions/<%= user.referralCode %>" class="text-gray-700">Transactions</a></li>
            <% } %>

            <li><a href="/logout" class="text-red-500">Logout</a></li>
        </ul>
    </div>

    <!-- Main Content -->
    <div class="flex-1 p-10">

        <h1 class="text-3xl font-bold mb-6">
            Welcome, <%= user.name %> 👋
        </h1>

        <!-- Cards -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">

            <div class="bg-white p-6 rounded-xl shadow">
                <h3 class="text-gray-500">Total Donations</h3>
                <p class="text-2xl font-bold text-green-600">₹<%= totalDonations %></p>
            </div>

            <div class="bg-white p-6 rounded-xl shadow">
                <h3 class="text-gray-500">Total Donors</h3>
                <p class="text-2xl font-bold text-blue-600"><%= totalDonors %></p>
            </div>

        </div>

        <!-- Referral Section -->
        <div class="bg-white p-6 rounded-xl shadow">

            <% if (!user.referralCode) { %>

                <p class="mb-4 text-gray-600">
                    Start fundraising to generate your link.
                </p>

                <button onclick="generateReferral()" 
                    class="bg-blue-600 text-white px-5 py-2 rounded-lg hover:bg-blue-700">
                    🚀 Generate Link
                </button>

            <% } else { %>

                <p class="mb-4">
                    <strong>Referral Code:</strong> 
                    <span id="referralCode"><%= user.referralCode %></span>
                </p>

                <div class="space-x-3">
                    <button onclick="copyDonationLink()" 
                        class="bg-green-600 text-white px-4 py-2 rounded-lg hover:bg-green-700">
                        📋 Copy Link
                    </button>

                    <button onclick="shareOnWhatsApp()" 
                        class="bg-emerald-500 text-white px-4 py-2 rounded-lg hover:bg-emerald-600">
                        📲 WhatsApp
                    </button>
                </div>

            <% } %>

        </div>

    </div>

</div>

<script>
function generateReferral() {
    window.location.href = "/generate-referral";
}

function getDonationLink() {
    const code = document.getElementById("referralCode")?.innerText;
    return `${window.location.origin}/donations/${code}`;
}

function copyDonationLink() {
    const link = getDonationLink();
    navigator.clipboard.writeText(link);
    alert("Link copied!");
}

function shareOnWhatsApp() {
    const link = getDonationLink();
    window.open(`https://wa.me/?text=${encodeURIComponent(link)}`);
}
</script>

</body>
</html>