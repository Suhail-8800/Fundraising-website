<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Dashboard</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100">

<div class="flex min-h-screen">

    <!-- Sidebar -->
    <div class="w-64 bg-gradient-to-b from-blue-600 to-indigo-700 text-white p-6">

        <h2 class="text-2xl font-bold mb-10">Fundraiser</h2>

        <ul class="space-y-5">
            <li>
                <a href="/dashboard" class="block hover:text-gray-200">
                    📊 Dashboard
                </a>
            </li>

            <% if (user.referralCode) { %>
            <li>
                <a href="/transactions/<%= user.referralCode %>" class="block hover:text-gray-200">
                    💰 Transactions
                </a>
            </li>
            <% } %>

            <li>
                <a href="/logout" class="block text-red-200 hover:text-white">
                    🚪 Logout
                </a>
            </li>
        </ul>

    </div>

    <!-- Main Content -->
    <div class="flex-1 p-10">

        <!-- Header -->
        <h1 class="text-3xl font-bold mb-8">
            Welcome, <%= user.name %> 👋
        </h1>

        <!-- Cards -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-10">

            <div class="bg-gradient-to-r from-green-500 to-emerald-600 text-white p-6 rounded-xl shadow-lg">
                <h3 class="text-lg">Total Donations</h3>
                <p class="text-3xl font-bold mt-2">₹<%= totalDonations %></p>
            </div>

            <div class="bg-gradient-to-r from-blue-500 to-indigo-600 text-white p-6 rounded-xl shadow-lg">
                <h3 class="text-lg">Total Donors</h3>
                <p class="text-3xl font-bold mt-2"><%= totalDonors %></p>
            </div>

        </div>

        <!-- Referral Section -->
        <div class="bg-white p-6 rounded-xl shadow-lg">

            <% if (!user.referralCode) { %>

                <p class="mb-4 text-gray-600">
                    Start fundraising to generate your link.
                </p>

                <button onclick="generateReferral()" 
                    class="bg-blue-600 text-white px-5 py-2 rounded-lg hover:bg-blue-700">
                    🚀 Generate Link
                </button>

            <% } else { %>

                <h3 class="text-lg font-semibold mb-4">Your Fundraising Link</h3>

                <div class="flex items-center bg-gray-100 p-3 rounded-lg mb-4">
                    <input id="donationLink" type="text" readonly
                        value="<%= referralLink %>"
                        class="w-full bg-transparent outline-none">
                </div>

                <div class="flex gap-3">
                    <button onclick="copyDonationLink()" 
                        class="bg-green-600 text-white px-4 py-2 rounded-lg hover:bg-green-700">
                        📋 Copy
                    </button>

                    <button onclick="shareOnWhatsApp()" 
                        class="bg-emerald-500 text-white px-4 py-2 rounded-lg hover:bg-emerald-600">
                        📲 WhatsApp
                    </button>
                </div>

            <% } %>

        </div>

    </div>

</div>

<script>
function generateReferral() {
    window.location.href = "/generate-referral";
}

function getDonationLink() {
    return document.getElementById("donationLink")?.value;
}

function copyDonationLink() {
    const link = getDonationLink();
    navigator.clipboard.writeText(link);
    alert("Link copied!");
}

function shareOnWhatsApp() {
    const link = getDonationLink();
    window.open(`https://wa.me/?text=${encodeURIComponent(link)}`);
}
</script>

</body>
</html>