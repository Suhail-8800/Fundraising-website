<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Fundraiser</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-50">

    <!-- Navbar -->
    <%- include('partials/navbar') %>

    <!-- Hero Section -->
    <section class="text-center py-20 bg-gradient-to-r from-blue-500 to-indigo-600 text-white">
        <h1 class="text-4xl md:text-5xl font-bold mb-6">
            Raise Funds for What Matters ❤️
        </h1>

        <p class="text-lg mb-8 max-w-2xl mx-auto">
            Create your own fundraising campaign and share it with the world.
            Fast, secure, and transparent donations.
        </p>

        <a href="/signup" 
           class="bg-white text-blue-600 px-8 py-3 rounded-lg font-semibold hover:bg-gray-100">
            🚀 Start Fundraising
        </a>
    </section>

    <!-- Features -->
    <section class="max-w-7xl mx-auto px-6 py-16 grid md:grid-cols-3 gap-10 text-center">

        <div class="bg-white p-6 rounded-xl shadow">
            <h3 class="text-xl font-semibold mb-3">🔗 Easy Sharing</h3>
            <p class="text-gray-600">Get a unique link and share it instantly.</p>
        </div>

        <div class="bg-white p-6 rounded-xl shadow">
            <h3 class="text-xl font-semibold mb-3">💳 Secure Payments</h3>
            <p class="text-gray-600">Powered by Razorpay for safe transactions.</p>
        </div>

        <div class="bg-white p-6 rounded-xl shadow">
            <h3 class="text-xl font-semibold mb-3">📊 Live Dashboard</h3>
            <p class="text-gray-600">Track donations in real-time.</p>
        </div>

    </section>

    <!-- CTA Section -->
    <section class="bg-blue-600 text-white text-center py-16">
        <h2 class="text-3xl font-bold mb-4">
            Start Your Fundraising Journey Today
        </h2>

        <a href="/signup"
           class="bg-white text-blue-600 px-6 py-3 rounded-lg font-semibold hover:bg-gray-100">
            Create Account
        </a>
    </section>

    <!-- Footer -->
    <%- include('partials/footer') %>

</body>
</html>