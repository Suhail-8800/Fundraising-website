<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Fundraiser - Premium Fundraising Platform</title>
    <%- include('partials/header_assets') %>
</head>

<body class="bg-gray-50 dark:bg-gray-900 text-gray-900 dark:text-gray-100 min-h-screen flex flex-col transition-colors duration-300">

    <%- include('partials/navbar') %>

    <!-- Hero Section (JS Slider) -->
    <section class="relative w-full h-[600px] overflow-hidden bg-gray-900 flex-shrink-0">
        <!-- Slide Container -->
        <div id="hero-slider" class="w-full h-full relative">
            
            <!-- Slide 1 -->
            <div class="hero-slide absolute inset-0 w-full h-full opacity-100 transition-opacity duration-1000 ease-in-out z-10">
                <div class="absolute inset-0 bg-gradient-to-r from-blue-700/90 to-indigo-900/90 mix-blend-multiply"></div>
                <div class="relative z-20 h-full max-w-7xl mx-auto px-6 flex flex-col justify-center items-start text-white">
                    <h1 class="text-6xl md:text-7xl font-black tracking-tight mb-6 animate-slide-up leading-tight drop-shadow-md">
                        Create your fundraiser <br/><span class="text-brand-400">in seconds.</span>
                    </h1>
                    <p class="text-xl max-w-xl text-gray-200 mb-8 animate-fade-in opacity-0 leading-relaxed font-medium" style="animation-delay: 0.2s; animation-fill-mode: forwards;">
                        Launch your campaign instantly. No technical skills required. Start raising funds for what matters most today.
                    </p>
                    <a href="/signup" class="bg-brand-500 hover:bg-brand-400 text-white px-8 py-4 rounded-xl font-bold text-lg shadow-xl shadow-brand-500/40 transition-all transform hover:-translate-y-1 animate-fade-in opacity-0" style="animation-delay: 0.4s; animation-fill-mode: forwards;">
                        Start Fundraising Now
                    </a>
                    <div class="mt-5 flex items-center gap-3 text-sm text-gray-300 font-medium animate-fade-in opacity-0" style="animation-delay: 0.6s; animation-fill-mode: forwards;">
                        <svg class="w-5 h-5 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
                        No hidden fees &bull; Bank-grade security &bull; Trusted by 10,000+
                    </div>
                </div>
            </div>

            <!-- Slide 2 -->
            <div class="hero-slide absolute inset-0 w-full h-full opacity-0 transition-opacity duration-1000 ease-in-out z-0">
                <div class="absolute inset-0 bg-gradient-to-r from-emerald-700/90 to-teal-900/90 mix-blend-multiply"></div>
                <div class="relative z-20 h-full max-w-7xl mx-auto px-6 flex flex-col justify-center items-start text-white">
                    <h1 class="text-5xl md:text-6xl font-extrabold tracking-tight mb-6">
                        Share your link <br/><span class="text-emerald-400">instantly.</span>
                    </h1>
                    <p class="text-xl max-w-xl text-gray-200 mb-8">
                        Get a unique short-link. One tap to share via WhatsApp, Email, and Social Media. Watch your donors grow.
                    </p>
                    <a href="/login" class="bg-emerald-500 hover:bg-emerald-400 text-white px-8 py-4 rounded-xl font-bold text-lg shadow-lg shadow-emerald-500/50 transition-all transform hover:-translate-y-1">
                        Go to Dashboard
                    </a>
                </div>
            </div>

            <!-- Slide 3 -->
            <div class="hero-slide absolute inset-0 w-full h-full opacity-0 transition-opacity duration-1000 ease-in-out z-0">
                <div class="absolute inset-0 bg-gradient-to-r from-purple-700/90 to-fuchsia-900/90 mix-blend-multiply"></div>
                <div class="relative z-20 h-full max-w-7xl mx-auto px-6 flex flex-col justify-center items-start text-white">
                    <h1 class="text-5xl md:text-6xl font-extrabold tracking-tight mb-6">
                        Receive payments <br/><span class="text-purple-400">securely.</span>
                    </h1>
                    <p class="text-xl max-w-xl text-gray-200 mb-8">
                        Powered by Razorpay. Accept UPI, NetBanking, Credit and Debit cards. 100% secure tracking in real-time.
                    </p>
                    <a href="/signup" class="bg-purple-500 hover:bg-purple-400 text-white px-8 py-4 rounded-xl font-bold text-lg shadow-lg shadow-purple-500/50 transition-all transform hover:-translate-y-1">
                        Create Account
                    </a>
                </div>
            </div>

        </div>

        <!-- Slider Controls -->
        <div class="absolute bottom-8 left-1/2 transform -translate-x-1/2 z-30 flex space-x-3">
            <button class="slider-dot w-3 h-3 rounded-full bg-white transition-opacity" data-index="0"></button>
            <button class="slider-dot w-3 h-3 rounded-full bg-white opacity-40 transition-opacity" data-index="1"></button>
            <button class="slider-dot w-3 h-3 rounded-full bg-white opacity-40 transition-opacity" data-index="2"></button>
        </div>
    </section>

    <!-- How it works -->
    <section class="max-w-7xl mx-auto px-6 py-20">
        <div class="text-center mb-16">
            <h2 class="text-3xl font-bold mb-4 dark:text-white">How it works</h2>
            <p class="text-gray-600 dark:text-gray-400 max-w-2xl mx-auto">Three simple steps to start receiving funds from anywhere in the world.</p>
        </div>
        <div class="grid md:grid-cols-3 gap-12 relative">
            <div class="hidden md:block absolute top-12 left-1/6 right-1/6 h-0.5 bg-gray-200 dark:bg-gray-800 z-0"></div>
            
            <div class="relative z-10 flex flex-col items-center text-center">
                <div class="w-16 h-16 rounded-2xl bg-brand-100 dark:bg-brand-900/30 text-brand-600 dark:text-brand-400 flex items-center justify-center text-2xl font-bold shadow-sm mb-6">1</div>
                <h3 class="text-xl font-semibold mb-3 dark:text-white">Sign Up</h3>
                <p class="text-gray-600 dark:text-gray-400 leading-relaxed">Create your free account in seconds. Access your personalized SaaS dashboard.</p>
            </div>
            
            <div class="relative z-10 flex flex-col items-center text-center">
                <div class="w-16 h-16 rounded-2xl bg-blue-100 dark:bg-blue-900/30 text-blue-600 dark:text-blue-400 flex items-center justify-center text-2xl font-bold shadow-sm mb-6">2</div>
                <h3 class="text-xl font-semibold mb-3 dark:text-white">Share Link</h3>
                <p class="text-gray-600 dark:text-gray-400 leading-relaxed">Generate your unique fundraising link and share it directly to WhatsApp.</p>
            </div>
            
            <div class="relative z-10 flex flex-col items-center text-center">
                <div class="w-16 h-16 rounded-2xl bg-green-100 dark:bg-green-900/30 text-green-600 dark:text-green-400 flex items-center justify-center text-2xl font-bold shadow-sm mb-6">3</div>
                <h3 class="text-xl font-semibold mb-3 dark:text-white">Get Funded</h3>
                <p class="text-gray-600 dark:text-gray-400 leading-relaxed">Receive secure payments instantly through Razorpay. Track live donors.</p>
            </div>
        </div>
    </section>

    <!-- Features -->
    <section class="bg-white dark:bg-gray-800/50 py-20 border-y border-gray-100 dark:border-gray-800">
        <div class="max-w-7xl mx-auto px-6 grid md:grid-cols-2 lg:grid-cols-3 gap-8">
            <div class="glass p-8 rounded-2xl hover:-translate-y-1 transition-transform duration-300">
                <div class="w-12 h-12 bg-blue-100 dark:bg-blue-900/40 text-blue-600 dark:text-blue-400 rounded-xl flex items-center justify-center mb-6">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
                </div>
                <h3 class="text-xl font-bold mb-3 dark:text-white">Lightning Fast</h3>
                <p class="text-gray-600 dark:text-gray-400">Zero approval times. Your link is active the second you generate it.</p>
            </div>

            <div class="glass p-8 rounded-2xl hover:-translate-y-1 transition-transform duration-300">
                <div class="w-12 h-12 bg-green-100 dark:bg-green-900/40 text-green-600 dark:text-green-400 rounded-xl flex items-center justify-center mb-6">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
                </div>
                <h3 class="text-xl font-bold mb-3 dark:text-white">Bank-Grade Security</h3>
                <p class="text-gray-600 dark:text-gray-400">All data transfers and payments are secured via Razorpay infrastructure.</p>
            </div>

            <div class="glass p-8 rounded-2xl hover:-translate-y-1 transition-transform duration-300">
                <div class="w-12 h-12 bg-purple-100 dark:bg-purple-900/40 text-purple-600 dark:text-purple-400 rounded-xl flex items-center justify-center mb-6">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                </div>
                <h3 class="text-xl font-bold mb-3 dark:text-white">Transparent Tracking</h3>
                <p class="text-gray-600 dark:text-gray-400">View real-time donors, transaction logs, and success rates on your dashboard.</p>
            </div>
        </div>
    </section>

    <div class="mt-auto">
        <!-- Footer -->
        <%- include('partials/footer') %>
    </div>

    <!-- JS Slider Logic -->
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const slides = document.querySelectorAll('.hero-slide');
            const dots = document.querySelectorAll('.slider-dot');
            let currentSlide = 0;
            const slideCount = slides.length;
            let slideInterval;

            function goToSlide(index) {
                // Remove active classes
                slides[currentSlide].classList.remove('z-10');
                slides[currentSlide].classList.add('z-0', 'opacity-0');
                slides[currentSlide].classList.remove('opacity-100');
                dots[currentSlide].classList.add('opacity-40');
                
                // Add active to new
                currentSlide = index;
                slides[currentSlide].classList.remove('z-0', 'opacity-0');
                slides[currentSlide].classList.add('z-10', 'opacity-100');
                dots[currentSlide].classList.remove('opacity-40');
            }

            function nextSlide() {
                let next = (currentSlide + 1) % slideCount;
                goToSlide(next);
            }

            // Init interval
            slideInterval = setInterval(nextSlide, 5000);

            // Dot clicks
            dots.forEach((dot, index) => {
                dot.addEventListener('click', () => {
                    clearInterval(slideInterval);
                    goToSlide(index);
                    slideInterval = setInterval(nextSlide, 5000);
                });
            });
        });
    </script>
</body>
</html>