<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Signup - Fundraiser</title>
    <%- include('partials/header_assets') %>
</head>

<body class="bg-gray-50 dark:bg-gray-900 text-gray-900 dark:text-gray-100 min-h-screen flex flex-col transition-colors duration-300">

    <%- include('partials/navbar') %>

    <!-- Signup Container -->
    <div class="flex flex-1 items-center justify-center p-6 relative overflow-hidden">
        
        <!-- Background Decorations -->
        <div class="absolute top-[-10%] right-[-10%] w-[40%] h-[40%] rounded-full bg-brand-500/20 blur-[100px] pointer-events-none"></div>
        <div class="absolute bottom-[-10%] left-[-10%] w-[40%] h-[40%] rounded-full bg-blue-500/20 blur-[100px] pointer-events-none"></div>

        <div class="glass p-10 rounded-3xl shadow-xl w-full max-w-md relative z-10 animate-slide-up bg-white/70 dark:bg-gray-800/70 backdrop-blur-xl">

            <div class="text-center mb-8">
                <div class="h-12 w-12 bg-gradient-to-br from-brand-500 to-blue-600 text-white rounded-xl shadow-lg flex items-center justify-center mx-auto mb-4">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"></path></svg>
                </div>
                <h2 class="text-2xl font-bold dark:text-white">Create Account 🚀</h2>
                <p class="text-gray-500 dark:text-gray-400 mt-2 text-sm">Join us and start raising funds today.</p>
            </div>

            <form id="authForm" action="/signup" method="POST" class="space-y-5">
                
                <div id="errorBox" class="hidden bg-red-50 text-red-600 dark:bg-red-900/30 dark:text-red-400 p-4 rounded-xl text-sm font-semibold flex items-start gap-2 border border-red-100 dark:border-red-800 transition-all">
                    <svg class="w-5 h-5 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    <span id="errorText"></span>
                </div>

                <div class="relative">
                    <input type="text" id="name" name="name" class="floating-label-input block px-4 py-3.5 w-full text-sm text-gray-900 bg-transparent rounded-xl border border-gray-300 appearance-none dark:text-white dark:border-gray-600 dark:focus:border-brand-500 focus:outline-none focus:ring-0 focus:border-brand-500 peer transition-colors" placeholder=" " required minlength="2" />
                    <label for="name" class="absolute text-sm text-gray-500 dark:text-gray-400 duration-300 transform -translate-y-4 scale-75 top-2 z-10 origin-[0] bg-white dark:bg-gray-800 px-2 peer-focus:px-2 peer-focus:text-brand-600 peer-focus:dark:text-brand-500 peer-placeholder-shown:scale-100 peer-placeholder-shown:-translate-y-1/2 peer-placeholder-shown:top-1/2 peer-focus:top-2 peer-focus:scale-75 peer-focus:-translate-y-4 left-3 rounded-md">Full Name</label>
                </div>

                <div class="relative">
                    <input type="email" id="email" name="email" class="floating-label-input block px-4 py-3.5 w-full text-sm text-gray-900 bg-transparent rounded-xl border border-gray-300 appearance-none dark:text-white dark:border-gray-600 dark:focus:border-brand-500 focus:outline-none focus:ring-0 focus:border-brand-500 peer transition-colors" placeholder=" " required pattern="[a-z0-9._%+-]+@[a-z0-9.-]+\.[a-z]{2,}$" />
                    <label for="email" class="absolute text-sm text-gray-500 dark:text-gray-400 duration-300 transform -translate-y-4 scale-75 top-2 z-10 origin-[0] bg-white dark:bg-gray-800 px-2 peer-focus:px-2 peer-focus:text-brand-600 peer-focus:dark:text-brand-500 peer-placeholder-shown:scale-100 peer-placeholder-shown:-translate-y-1/2 peer-placeholder-shown:top-1/2 peer-focus:top-2 peer-focus:scale-75 peer-focus:-translate-y-4 left-3 rounded-md">Email Address</label>
                </div>

                <div class="relative">
                    <input type="password" id="password" name="password" minlength="6" class="floating-label-input block px-4 py-3.5 w-full text-sm text-gray-900 bg-transparent rounded-xl border border-gray-300 appearance-none dark:text-white dark:border-gray-600 dark:focus:border-brand-500 focus:outline-none focus:ring-0 focus:border-brand-500 peer transition-colors" placeholder=" " required />
                    <label for="password" class="absolute text-sm text-gray-500 dark:text-gray-400 duration-300 transform -translate-y-4 scale-75 top-2 z-10 origin-[0] bg-white dark:bg-gray-800 px-2 peer-focus:px-2 peer-focus:text-brand-600 peer-focus:dark:text-brand-500 peer-placeholder-shown:scale-100 peer-placeholder-shown:-translate-y-1/2 peer-placeholder-shown:top-1/2 peer-focus:top-2 peer-focus:scale-75 peer-focus:-translate-y-4 left-3 rounded-md">Password</label>
                </div>

                <button type="submit" id="submitBtn" class="w-full bg-brand-600 text-white py-3.5 rounded-xl hover:bg-brand-700 shadow-md shadow-brand-500/20 transition-all font-semibold flex justify-center items-center gap-2 mt-2 disabled:opacity-70 disabled:cursor-not-allowed">
                    <span id="btnText">Create Account</span>
                    <svg id="btnLoader" class="hidden animate-spin h-5 w-5 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
                </button>

            </form>

            <p class="text-center mt-6 text-sm text-gray-600 dark:text-gray-400">
                Already have an account? 
                <a href="/login" class="text-brand-600 dark:text-brand-400 font-semibold hover:underline">Sign In</a>
            </p>

        </div>

    </div>

<script>
document.getElementById('authForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.target;
    const submitBtn = document.getElementById('submitBtn');
    const btnText = document.getElementById('btnText');
    const btnLoader = document.getElementById('btnLoader');
    const errorBox = document.getElementById('errorBox');
    const errorText = document.getElementById('errorText');

    submitBtn.disabled = true;
    btnText.textContent = "Creating...";
    btnLoader.classList.remove('hidden');
    errorBox.classList.add('hidden');

    const elements = form.elements;
    Array.from(elements).forEach(el => el.classList?.remove('border-red-500', 'focus:border-red-500'));

    try {
        const formData = new FormData(form);
        const data = Object.fromEntries(formData.entries());

        const res = await fetch(form.action, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'Accept': 'application/json'
            },
            body: JSON.stringify(data)
        });

        const result = await res.json();

        if (res.ok && result.success) {
            if (window.showToast) window.showToast(result.message, 'success');
            setTimeout(() => {
                window.location.href = result.redirect || '/dashboard';
            }, 500);
        } else {
            errorText.textContent = result.message || 'An error occurred';
            errorBox.classList.remove('hidden');
            Array.from(elements).forEach(el => {
                if(el.tagName === 'INPUT') el.classList.add('border-red-500', 'focus:border-red-500');
            });
            if (window.showToast) window.showToast(result.message, 'error');
        }
    } catch (err) {
        errorText.textContent = 'A network error occurred. Please try again.';
        errorBox.classList.remove('hidden');
        if (window.showToast) window.showToast('Network error', 'error');
    } finally {
        submitBtn.disabled = false;
        btnText.textContent = "Create Account";
        btnLoader.classList.add('hidden');
    }
});
</script>

</body>
</html>