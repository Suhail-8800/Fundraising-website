<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Signup - Fundraiser</title>
    <%- include('partials/header_assets') %>
</head>

<body class="bg-gray-50 dark:bg-gray-900 text-gray-900 dark:text-gray-100 min-h-screen flex flex-col transition-colors duration-300">

    <%- include('partials/navbar') %>

    <!-- Signup Container -->
    <div class="flex flex-1 items-center justify-center p-6 relative overflow-hidden">
        
        <!-- Background Decorations -->
        <div class="absolute top-[-10%] right-[-10%] w-[40%] h-[40%] rounded-full bg-brand-500/20 blur-[100px] pointer-events-none"></div>
        <div class="absolute bottom-[-10%] left-[-10%] w-[40%] h-[40%] rounded-full bg-blue-500/20 blur-[100px] pointer-events-none"></div>

        <div class="glass p-10 rounded-3xl shadow-xl w-full max-w-md relative z-10 animate-slide-up bg-white/70 dark:bg-gray-800/70 backdrop-blur-xl">

            <div class="text-center mb-8">
                <div class="h-12 w-12 bg-gradient-to-br from-brand-500 to-blue-600 text-white rounded-xl shadow-lg flex items-center justify-center mx-auto mb-4">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"></path></svg>
                </div>
                <h2 class="text-2xl font-bold dark:text-white">Create Account 🚀</h2>
                <p class="text-gray-500 dark:text-gray-400 mt-2 text-sm">Join us and start raising funds today.</p>
            </div>

            <form action="/signup" method="POST" class="space-y-5">
                
                <div class="relative">
                    <input type="text" id="name" name="name" class="floating-label-input block px-4 py-3.5 w-full text-sm text-gray-900 bg-transparent rounded-xl border border-gray-300 appearance-none dark:text-white dark:border-gray-600 dark:focus:border-brand-500 focus:outline-none focus:ring-0 focus:border-brand-500 peer transition-colors" placeholder=" " required />
                    <label for="name" class="absolute text-sm text-gray-500 dark:text-gray-400 duration-300 transform -translate-y-4 scale-75 top-2 z-10 origin-[0] bg-white dark:bg-gray-800 px-2 peer-focus:px-2 peer-focus:text-brand-600 peer-focus:dark:text-brand-500 peer-placeholder-shown:scale-100 peer-placeholder-shown:-translate-y-1/2 peer-placeholder-shown:top-1/2 peer-focus:top-2 peer-focus:scale-75 peer-focus:-translate-y-4 left-3 rounded-md">Full Name</label>
                </div>

                <div class="relative">
                    <input type="email" id="email" name="email" class="floating-label-input block px-4 py-3.5 w-full text-sm text-gray-900 bg-transparent rounded-xl border border-gray-300 appearance-none dark:text-white dark:border-gray-600 dark:focus:border-brand-500 focus:outline-none focus:ring-0 focus:border-brand-500 peer transition-colors" placeholder=" " required />
                    <label for="email" class="absolute text-sm text-gray-500 dark:text-gray-400 duration-300 transform -translate-y-4 scale-75 top-2 z-10 origin-[0] bg-white dark:bg-gray-800 px-2 peer-focus:px-2 peer-focus:text-brand-600 peer-focus:dark:text-brand-500 peer-placeholder-shown:scale-100 peer-placeholder-shown:-translate-y-1/2 peer-placeholder-shown:top-1/2 peer-focus:top-2 peer-focus:scale-75 peer-focus:-translate-y-4 left-3 rounded-md">Email Address</label>
                </div>

                <div class="relative">
                    <input type="password" id="password" name="password" class="floating-label-input block px-4 py-3.5 w-full text-sm text-gray-900 bg-transparent rounded-xl border border-gray-300 appearance-none dark:text-white dark:border-gray-600 dark:focus:border-brand-500 focus:outline-none focus:ring-0 focus:border-brand-500 peer transition-colors" placeholder=" " required />
                    <label for="password" class="absolute text-sm text-gray-500 dark:text-gray-400 duration-300 transform -translate-y-4 scale-75 top-2 z-10 origin-[0] bg-white dark:bg-gray-800 px-2 peer-focus:px-2 peer-focus:text-brand-600 peer-focus:dark:text-brand-500 peer-placeholder-shown:scale-100 peer-placeholder-shown:-translate-y-1/2 peer-placeholder-shown:top-1/2 peer-focus:top-2 peer-focus:scale-75 peer-focus:-translate-y-4 left-3 rounded-md">Password</label>
                </div>

                <button type="submit" class="w-full bg-brand-600 text-white py-3.5 rounded-xl hover:bg-brand-700 shadow-md shadow-brand-500/20 transition-all font-semibold mt-2">
                    Create Account
                </button>

            </form>

            <p class="text-center mt-6 text-sm text-gray-600 dark:text-gray-400">
                Already have an account? 
                <a href="/login" class="text-brand-600 dark:text-brand-400 font-semibold hover:underline">Sign In</a>
            </p>

        </div>

    </div>

</body>
</html>