<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>404 - Page Not Found</title>
    <%- include('partials/header_assets') %>
</head>
<body class="bg-gray-50 dark:bg-gray-900 text-gray-900 dark:text-gray-100 min-h-screen flex flex-col transition-colors duration-300">

    <%- include('partials/navbar') %>

    <div class="flex-1 flex items-center justify-center p-6 relative overflow-hidden">
        <div class="absolute top-[20%] left-[20%] w-[40%] h-[40%] rounded-full bg-brand-500/10 blur-[120px] pointer-events-none"></div>
        <div class="glass p-12 rounded-3xl shadow-xl w-full max-w-lg text-center relative z-10 animate-fade-in bg-white/70 dark:bg-gray-800/70 backdrop-blur-xl border border-gray-100 dark:border-gray-700">
            <h1 class="text-8xl font-black text-transparent bg-clip-text bg-gradient-to-br from-brand-600 to-blue-600 mb-6 drop-shadow-sm">404</h1>
            <h2 class="text-3xl font-extrabold dark:text-white mb-4">Page not found</h2>
            <p class="text-gray-600 dark:text-gray-400 mb-8 text-lg">We looked everywhere, but it seems this link has moved or no longer exists.</p>
            <a href="/" class="inline-flex items-center gap-2 bg-gray-900 dark:bg-brand-500 text-white px-8 py-4 rounded-xl hover:bg-gray-800 dark:hover:bg-brand-400 font-bold transition-all shadow-xl shadow-gray-900/20 transform hover:-translate-y-1">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
                Go back Home
            </a>
        </div>
    </div>

</body>
</html>
