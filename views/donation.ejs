<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Donate</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100">

    <!-- Navbar -->
    <%- include('partials/navbar') %>

    <div class="flex items-center justify-center min-h-screen px-4">

        <div class="bg-white p-8 rounded-xl shadow-lg w-full max-w-md">

            <h2 class="text-2xl font-bold text-center mb-2">
                Support This Cause ❤️
            </h2>

            <p class="text-center text-gray-500 mb-6">
                Your contribution makes a difference
            </p>

            <!-- Form -->
            <form id="donationForm" class="space-y-4">

                <input type="text" id="donorName" placeholder="Your Name"
                    class="w-full border p-3 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500" required>

                <input type="number" id="amount" placeholder="Amount (₹)"
                    class="w-full border p-3 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500" required>

                <button type="button" onclick="payNow()"
                    class="w-full bg-green-600 text-white py-3 rounded-lg hover:bg-green-700 text-lg font-semibold">
                    💳 Donate Now
                </button>

            </form>

            <!-- Trust Section -->
            <div class="mt-6 text-center text-sm text-gray-500">
                🔒 Secure Payments powered by Razorpay
            </div>

        </div>

    </div>

    <!-- Razorpay Script -->
    <script src="https://checkout.razorpay.com/v1/checkout.js"></script>

    <script>
        async function payNow() {

            const donorName = document.getElementById("donorName").value;
            const amount = document.getElementById("amount").value;

            if (!donorName || !amount) {
                alert("Please fill all fields");
                return;
            }

            // Create order
            const res = await fetch("/donations/create-order", {
                method: "POST",
                headers: {
                    "Content-Type": "application/json"
                },
                body: JSON.stringify({ amount })
            });

            const order = await res.json();

            const options = {
                key: "<%= key %>",
                amount: order.amount,
                currency: "INR",
                name: "Fundraiser",
                description: "Donation",
                order_id: order.id,

                handler: async function (response) {

                    await fetch("/donations/verify", {
                        method: "POST",
                        headers: {
                            "Content-Type": "application/json"
                        },
                        body: JSON.stringify({
                            donorName,
                            donationAmount: amount,
                            referralCode: "<%= referralCode %>",
                            paymentId: response.razorpay_payment_id,
                            orderId: response.razorpay_order_id,
                            signature: response.razorpay_signature
                        })
                    });

                    alert("Payment Successful 🎉");
                    window.location.reload();
                },

                theme: {
                    color: "#2563eb"
                }
            };

            const rzp = new Razorpay(options);
            rzp.open();
        }
    </script>

</body>
</html>