<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>500 - Server Error</title>
    <%- include('partials/header_assets') %>
</head>
<body class="bg-gray-50 dark:bg-gray-900 text-gray-900 dark:text-gray-100 min-h-screen flex flex-col transition-colors duration-300">

    <%- include('partials/navbar') %>

    <div class="flex-1 flex items-center justify-center p-6 relative overflow-hidden">
        <div class="absolute top-[20%] right-[20%] w-[40%] h-[40%] rounded-full bg-red-500/10 blur-[120px] pointer-events-none"></div>
        <div class="glass p-12 rounded-3xl shadow-xl w-full max-w-lg text-center relative z-10 animate-fade-in bg-white/70 dark:bg-gray-800/70 backdrop-blur-xl border border-gray-100 dark:border-gray-700">
            <div class="h-20 w-20 bg-red-100 text-red-600 dark:bg-red-900/40 dark:text-red-400 rounded-full flex items-center justify-center mx-auto mb-6 shadow-sm">
                <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
            </div>
            <h2 class="text-3xl font-extrabold dark:text-white mb-4">Something went wrong</h2>
            <p class="text-gray-600 dark:text-gray-400 mb-8 text-lg">Our servers hit a temporary snag. We have logged the error and are looking into it.</p>
            <div class="flex flex-col sm:flex-row justify-center gap-4">
                <button onclick="window.location.reload()" class="bg-gray-100 text-gray-900 dark:bg-gray-700 dark:text-white px-8 py-3.5 rounded-xl hover:bg-gray-200 dark:hover:bg-gray-600 font-bold transition-all shadow-sm">
                    Try Again
                </button>
                <a href="/" class="bg-gray-900 dark:bg-brand-500 text-white px-8 py-3.5 rounded-xl hover:bg-gray-800 dark:hover:bg-brand-400 font-bold transition-all shadow-xl shadow-gray-900/20">
                    Go Home
                </a>
            </div>
        </div>
    </div>

</body>
</html>
